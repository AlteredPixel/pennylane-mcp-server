# ═══════════════════════════════════════════════════════════════════
#  Configuration du serveur MCP Pennylane
#  Copiez ce fichier en .env et remplissez vos valeurs :
#    cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ── Pennylane : mode mono-dossier ────────────────────────────────
# Votre token API Pennylane (Company Token)
# Obtenez-le dans Pennylane > Paramètres > Connectivité > Développeurs
PENNYLANE_API_TOKEN=votre_token_pennylane_ici

# ── Pennylane : mode multi-dossiers (recommandé pour les cabinets)
# Chemin vers le fichier de configuration des dossiers
# PENNYLANE_CONFIG_PATH=./dossiers.json

# Si dossiers.json référence un token via "${MA_VARIABLE}", définissez-la
# ici (le token réel ne sera alors jamais écrit en clair sur disque).
# PENNYLANE_TOKEN_SARL_DUPONT=votre_token_dupont_ici

# ── Transport SSE (usage distant uniquement) ─────────────────────
# MCP_TRANSPORT=sse
# MCP_HOST=127.0.0.1
# MCP_PORT=8000

# Obligatoire en mode SSE : le serveur refuse de démarrer sans ce token.
# Les clients distants doivent envoyer "Authorization: Bearer <valeur>".
# MCP_AUTH_TOKEN=un_secret_long_et_aleatoire

# ── Mode lecture seule ────────────────────────────────────────────
# true/1/yes : n'expose que les outils de consultation (list_*/get_*),
# masque création/modification/suppression/envoi.
# MCP_READONLY=false
