# ═══════════════════════════════════════════════════════════════════
#  Configuration du serveur MCP Pennylane
#  Copiez ce fichier en .env et remplissez vos valeurs :
#    cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ── Pennylane (obligatoire) ──────────────────────────────────────
# Votre token API Pennylane (Company Token)
# Obtenez-le dans Pennylane > Paramètres > Connectivité > Développeurs
PENNYLANE_API_TOKEN=votre_token_pennylane_ici

# ── Transport (optionnel) ────────────────────────────────────────
# 'stdio' (défaut, usage local) ou 'sse' (usage distant)
# MCP_TRANSPORT=stdio

# ── Mode SSE uniquement ──────────────────────────────────────────
# MCP_HOST=127.0.0.1
# MCP_PORT=8000
# Token d'authentification OBLIGATOIRE en mode SSE (long et aléatoire)
# MCP_AUTH_TOKEN=changez_moi_par_un_secret_aleatoire
